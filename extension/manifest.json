{
  "manifest_version": 3,
  "name": "HQ OCR Translator",
  "version": "0.1.0",
  "description": "Selecione uma area visivel da HQ e traduza com OCR local.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:*/*", "http://localhost:*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Traduzir area da HQ",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
